{
  "name": "@valtren-ai/extension-sdk",
  "version": "0.2.1",
  "description": "Types, helpers, validators, and scaffolds for building Valtren AI extensions.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/valtren-ai/extension-sdk.git"
  },
  "homepage": "https://github.com/valtren-ai/extension-sdk#readme",
  "bugs": {
    "url": "https://github.com/valtren-ai/extension-sdk/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js"
    },
    "./validate": {
      "types": "./dist/validate.d.ts",
      "import": "./dist/validate.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "valtren",
    "ai",
    "extensions",
    "workflow",
    "agents"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.2.4",
    "typescript": "^5.6.3"
  },
  "bin": {
    "create-valtren-extension": "./bin/create-valtren-extension.mjs"
  }
}
